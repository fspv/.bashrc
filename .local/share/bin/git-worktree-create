#!/usr/bin/env python3

import argparse
import logging
import re
import subprocess
import sys
from pathlib import Path

logging.basicConfig(
    level=logging.INFO,
    format="%(message)s",
)
log = logging.getLogger(__name__)

WORKTREE_BASE = Path.home() / "git"


def run_git(args: list[str], capture: bool = True) -> str:
    cmd = ["git"] + args
    log.debug("Running: %s", " ".join(cmd))
    result = subprocess.run(cmd, capture_output=capture, text=True, check=True)
    return result.stdout.strip() if capture else ""


def get_remote_url(remote: str) -> str:
    return run_git(["remote", "get-url", remote])


def list_remotes() -> list[str]:
    output = run_git(["remote"])
    return [r for r in output.splitlines() if r]


def parse_remote_url(url: str) -> tuple[str, str, str]:
    """Parse remote URL into (host, org, repo) tuple."""
    ssh_match = re.match(r"^git@([^:]+):(.+)/(.+?)(?:\.git)?$", url)
    if ssh_match:
        return ssh_match.group(1), ssh_match.group(2), ssh_match.group(3)

    https_match = re.match(r"^https?://([^/]+)/(.+)/(.+?)(?:\.git)?$", url)
    if https_match:
        return https_match.group(1), https_match.group(2), https_match.group(3)

    raise ValueError(f"Cannot parse remote URL: {url}")


def get_worktree_base_path(remote: str) -> Path:
    url = get_remote_url(remote)
    host, org, repo = parse_remote_url(url)
    return WORKTREE_BASE / host / org / f"{repo}-worktrees"


def list_local_branches() -> list[str]:
    output = run_git(["branch", "--format=%(refname:short)"])
    return [b for b in output.splitlines() if b]


def list_remote_branches(remote: str) -> list[str]:
    output = run_git(["branch", "-r", "--format=%(refname:short)"])
    prefix = f"{remote}/"
    branches = []
    for b in output.splitlines():
        if b.startswith(prefix) and not b.endswith("/HEAD"):
            branches.append(b[len(prefix) :])
    return branches


def select_branch_with_fzf(branches: list[str]) -> str | None:
    if not branches:
        raise ValueError("No branches available")

    cmd = ["fzf", "--height=40%", "--reverse", "--prompt=Select branch: "]
    log.debug("Running: %s", " ".join(cmd))

    result = subprocess.run(
        cmd,
        input="\n".join(branches),
        capture_output=True,
        text=True,
    )

    if result.returncode != 0:
        return None

    return result.stdout.strip()


def create_worktree(base_path: Path, branch: str) -> Path:
    worktree_path = base_path / branch

    if worktree_path.exists():
        raise FileExistsError(f"Worktree path already exists: {worktree_path}")

    worktree_path.parent.mkdir(parents=True, exist_ok=True)

    cmd = ["git", "worktree", "add", str(worktree_path), branch]
    log.info("Running: %s", " ".join(cmd))
    subprocess.run(cmd, check=True)

    return worktree_path


def create_tmux_session(worktree_path: Path) -> None:
    # tmux forbids '.' and ':' in session names
    session_name = re.sub(r"[.:]", "-", str(worktree_path.relative_to(Path.home())))

    # Check if session already exists.
    result = subprocess.run(
        ["tmux", "has-session", "-t", session_name],
        capture_output=True,
    )
    if result.returncode == 0:
        log.info("tmux session '%s' already exists", session_name)
        return

    cmd = ["tmux", "new-session", "-d", "-s", session_name, "-c", str(worktree_path)]
    log.info("Creating tmux session: %s", session_name)
    subprocess.run(cmd, check=True)

    subprocess.run(
        ["tmux", "split-window", "-h", "-t", session_name, "-c", str(worktree_path)],
        check=True,
    )
    subprocess.run(
        ["tmux", "split-window", "-v", "-t", session_name, "-c", str(worktree_path)],
        check=True,
    )


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Create a git worktree with interactive branch selection"
    )
    parser.add_argument(
        "--remote",
        default="origin",
        help="Git remote to use for path resolution (default: origin)",
    )
    parser.add_argument(
        "--include-remote",
        action="store_true",
        help="Include remote-tracking branches in selection",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Enable verbose output",
    )
    args = parser.parse_args()

    if args.verbose:
        logging.getLogger().setLevel(logging.DEBUG)

    remotes = list_remotes()
    if args.remote not in remotes:
        log.error(
            "Remote '%s' not found. Available remotes: %s",
            args.remote,
            ", ".join(remotes),
        )
        return 1

    base_path = get_worktree_base_path(args.remote)
    log.debug("Worktree base path: %s", base_path)

    branches = list_local_branches()
    if args.include_remote:
        remote_branches = list_remote_branches(args.remote)
        for rb in remote_branches:
            if rb not in branches:
                branches.append(rb)

    branches.sort()

    selected = select_branch_with_fzf(branches)
    if not selected:
        log.info("No branch selected")
        return 0

    worktree_path = create_worktree(base_path, selected)
    create_tmux_session(worktree_path)
    print(worktree_path)

    return 0


if __name__ == "__main__":
    sys.exit(main())
