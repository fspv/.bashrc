#!/usr/bin/env python3
"""Print the main repo root when inside a git worktree.

Exit 0 = worktree (path printed), exit 1 = not a worktree.
"""

import os
import subprocess
import sys


def git(*args: str) -> str | None:
    try:
        return subprocess.check_output(
            ["git", *args], stderr=subprocess.DEVNULL, text=True
        ).strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def main() -> int:
    git_dir = git("rev-parse", "--git-dir")
    if git_dir is None:
        return 1

    common_dir = git("rev-parse", "--git-common-dir")
    if common_dir is None:
        return 1

    abs_git_dir = os.path.realpath(git_dir)
    abs_common_dir = os.path.realpath(common_dir)

    if abs_git_dir == abs_common_dir:
        return 1

    print(os.path.dirname(abs_common_dir))
    return 0


if __name__ == "__main__":
    sys.exit(main())
